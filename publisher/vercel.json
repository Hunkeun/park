{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/covers/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/qr/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/epubs/(.*).epub",
      "headers": [
        { "key": "Content-Type", "value": "application/epub+zip" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/books_master.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/build_info.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=10, must-revalidate" }
      ]
    }
  ]
}
